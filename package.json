{
  "name": "todo-ui",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "ng build",
    "build:dev": "npm run build -- --configuration development",
    "cypress:headless": "cypress run --config-file cypress/cypress.config.ts --headless -b chrome",
    "cypress:open": "cypress open --config-file cypress/cypress.config.ts",
    "lint": "npm run lint:angular && npm run lint:cypress",
    "lint:angular": "ng lint",
    "lint:cypress": "eslint -c ./cypress/eslint.config.js ./cypress",
    "lint:fix": "npm run lint:angular -- --fix && npm run lint:cypress -- --fix",
    "ng": "ng",
    "prepare": "husky",
    "prettier": "prettier --write . --ignore-unknown",
    "prettier:test": "prettier --check . --ignore-unknown",
    "start": "ng serve",
    "sync:agent-instructions": "node scripts/sync-agent-instructions.mjs",
    "sync:agent-instructions:check": "node scripts/sync-agent-instructions.mjs --check",
    "test": "npm run test:unit && npm run test:cypress",
    "test:cypress": "start-server-and-test start http://localhost:4200 cypress:headless",
    "test:cypress:open": "start-server-and-test start http://localhost:4200 cypress:open",
    "test:unit": "ng test --no-watch",
    "watch": "ng build --watch --configuration development"
  },
  "lint-staged": {
    ".vscode/settings.json": [
      "sort-json --indent 2 --depth 4",
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json",
      "prettier --write"
    ],
    "cypress/**/*.ts": [
      "eslint -c ./cypress/eslint.config.js --fix"
    ],
    "src/**/*.{html,ts}": [
      "ng-lint-staged lint:angular --fix --"
    ],
    "!({.vscode/settings.json,package.json,cypress/**/*.ts,src/**/*.{html,ts}})": [
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "@angular/cdk": "^22",
    "@angular/common": "^22",
    "@angular/compiler": "^22",
    "@angular/core": "^22",
    "@angular/forms": "^22",
    "@angular/material": "^22",
    "@angular/platform-browser": "^22",
    "@angular/router": "^22",
    "iframe-resizer": "^4",
    "rxjs": "^7",
    "tslib": "^2"
  },
  "devDependencies": {
    "@angular/build": "^22",
    "@angular/cli": "^22",
    "@angular/compiler-cli": "^22",
    "@eslint/js": "^9",
    "@types/iframe-resizer": "^4",
    "@types/node": "^26",
    "@vitest/coverage-v8": "^4",
    "angular-eslint": "^22",
    "cypress": "^15",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-import-resolver-typescript": "^4",
    "eslint-plugin-cypress": "^6",
    "eslint-plugin-import": "^2",
    "eslint-plugin-prettier": "^5",
    "husky": "^9",
    "jsdom": "^29",
    "lint-staged": "^17",
    "ng-lint-staged": "^12",
    "prettier": "^3",
    "sort-json": "^2",
    "sort-package-json": "^4",
    "start-server-and-test": "^3",
    "typescript": "~6.0",
    "typescript-eslint": "^8",
    "vitest": "^4"
  },
  "packageManager": "npm@11.17.0",
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "cypress@15.18.0": true,
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true,
    "iframe-resizer@4.4.5": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true,
    "unrs-resolver@1.12.2": true
  }
}
